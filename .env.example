# =====================================================================
# holymog — environment variables
# =====================================================================
# Copy this file to .env.local and fill in the values. Anything left
# blank degrades gracefully — see the notes per variable for what
# breaks without it.
#
# In production (Vercel), set these in Project Settings → Environment
# Variables. Variables prefixed with NEXT_PUBLIC_ are exposed to the
# client; everything else is server-only.
# =====================================================================


# ---------------------------------------------------------------------
# Required: scoring
# ---------------------------------------------------------------------
# Google AI Studio key (https://aistudio.google.com/apikey). Drives
# /api/score, /api/quick-score, and /api/battle/score. Without it,
# those endpoints 503 with `vision_unavailable`.
GEMINI_API_KEY=

# Optional model override. Default is gemini-2.5-flash-lite, calibrated
# for the rubric in lib/vision.ts. Bumping to a heavier model changes
# token cost AND the score distribution — re-run the calibration
# rubric before swapping.
# GEMINI_MODEL=gemini-2.5-flash-lite


# ---------------------------------------------------------------------
# Required: database
# ---------------------------------------------------------------------
# Postgres connection string (Supabase → Project Settings → Database).
# Use the "Connection Pooling" URL (port 6543, pgbouncer) for serverless.
DATABASE_URL=

# Supabase REST + Storage. Both URL and anon key are public-ish — the
# anon key is fine to expose because RLS controls access.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Service-role key — bypasses RLS. Server-only. NEVER expose to the
# client. Used by API routes for writes that have already passed
# their own auth + ownership check.
SUPABASE_SERVICE_ROLE_KEY=

# Client-side Realtime subscription needs the same URL + anon key,
# exposed via NEXT_PUBLIC_ so the browser can use them.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=


# ---------------------------------------------------------------------
# Required: Auth.js v5
# ---------------------------------------------------------------------
# 32+ random bytes — generate with `openssl rand -base64 32`. Used
# for session cookie signing, anonymous-ID HMAC, email-change tokens,
# 2FA secret encryption. Rotating invalidates every active session.
AUTH_SECRET=

# Always true when behind Vercel + a custom auth domain (or any
# hosting that proxies). Lets Auth.js trust the X-Forwarded-Host
# header.
AUTH_TRUST_HOST=true

# Public base URL of the app. Used by Auth.js for callback URLs,
# email links, share text, and the Origin guard's allow-list.
# - Dev:        http://localhost:3000
# - Current:    https://holymog.vercel.app
# - Target:     https://www.holymog.com (after the .com flip)
NEXTAUTH_URL=https://holymog.vercel.app
NEXT_PUBLIC_APP_URL=https://holymog.vercel.app

# Cookie domain. Set ONLY after we flip from holymog.vercel.app to
# the custom domain split between www.holymog.com and auth.holymog.com.
# When set, session cookies are scoped to .holymog.com (shared across
# subdomains). Leave commented out until then.
# AUTH_COOKIE_DOMAIN=.holymog.com


# ---------------------------------------------------------------------
# Required: Google OAuth (one-tap sign-in)
# ---------------------------------------------------------------------
# Cloud Console → APIs & Services → Credentials. Authorised redirect
# URIs must include BOTH:
#   - https://holymog.vercel.app/api/auth/callback/google
#   - https://auth.holymog.com/api/auth/callback/google
# so the .com flip doesn't require re-registering the OAuth app.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Mirror the activation flag on the client so the modal shows the
# real button (instead of "coming soon").
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=true


# ---------------------------------------------------------------------
# Optional: Apple OAuth
# ---------------------------------------------------------------------
# Service ID + JWT generated from a .p8 key (rotates every 6mo).
# See https://authjs.dev/getting-started/providers/apple for the
# JWT-generation script. Leave both blank to keep Apple disabled
# (the modal greys out the button until AUTH_APPLE_* + the client
# flag are both set).
# AUTH_APPLE_ID=
# AUTH_APPLE_SECRET=
# NEXT_PUBLIC_AUTH_APPLE_ENABLED=true


# ---------------------------------------------------------------------
# Email magic-link (Gmail Workspace SMTP — preferred)
# ---------------------------------------------------------------------
# Sends from auth@holymog.com via Workspace SMTP. EMAIL_SERVER_USER is
# the underlying mailbox (auth identity); EMAIL_FROM is the send-as
# alias (no separate mailbox needed). EMAIL_SERVER_PASSWORD is a
# 16-char Google app password — myaccount.google.com/apppasswords.
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=hello@holymog.com
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=auth@holymog.com

# Tells the client which provider id to pass to signIn(). Should be
# 'nodemailer' when Gmail SMTP is configured above, or 'resend' when
# falling back to Resend.
NEXT_PUBLIC_AUTH_EMAIL_PROVIDER=nodemailer


# ---------------------------------------------------------------------
# Email magic-link (Resend — fallback)
# ---------------------------------------------------------------------
# Activates when EMAIL_SERVER_PASSWORD is not set. Used for both
# magic-link delivery and for cron-driven emails (weekly digest,
# leaderboard-displaced alerts). Domain must be verified in Resend.
# AUTH_RESEND_KEY=
# AUTH_RESEND_FROM=auth@holymog.com


# ---------------------------------------------------------------------
# Required for battles: LiveKit Cloud
# ---------------------------------------------------------------------
# LiveKit Cloud → Project Settings. Without these, /api/battle/[id]/token
# fails and /mog gates with an error.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Public WebSocket endpoint (e.g. wss://holymog.livekit.cloud). Exposed
# to clients because they connect to it directly via @livekit/components-react.
NEXT_PUBLIC_LIVEKIT_URL=


# ---------------------------------------------------------------------
# Optional: Upstash rate limiting + budget cap
# ---------------------------------------------------------------------
# Upstash Redis. Without these, rate limiters disable (no limit applied)
# AND the daily Gemini budget cap (DAILY_GEMINI_BUDGET_USD below) is
# effectively disabled — checkBudget() falls open. Production should
# always have these set.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# ---------------------------------------------------------------------
# Required for crons: Vercel Cron auth
# ---------------------------------------------------------------------
# Set by Vercel automatically when you enable Cron Jobs in the project
# dashboard. Cron routes verify `Authorization: Bearer ${CRON_SECRET}`
# and 401 anything else. In dev without this set, cron routes accept
# unauthed requests for local testing.
CRON_SECRET=


# ---------------------------------------------------------------------
# Required for admin grants + S-tier review
# ---------------------------------------------------------------------
# Comma-separated list of user IDs that can call /api/admin/grant.
# Look up your user_id from `profiles` table after first sign-in.
ADMIN_USER_IDS=

# Inbox that receives email notifications when a scan flags for S-tier
# review (overall ≥ 87). Link in the email is a 7-day signed URL to
# the archived scan image.
ADMIN_REVIEW_EMAIL=

# Inbox for contact-form submissions from /help.
CONTACT_EMAIL=hello@holymog.com


# ---------------------------------------------------------------------
# Security knobs (added in the pre-launch security pass)
# ---------------------------------------------------------------------
# Daily Gemini spend cap in USD. When today's cumulative cost crosses
# this, /api/score, /api/quick-score, /api/battle/score all return 503
# until 00:00 UTC. Defaults to $50 if unset. Set higher in production
# once you've validated organic traffic isn't bouncing on it.
DAILY_GEMINI_BUDGET_USD=50

# Kill switches — flip any to `1` (or `true`/`yes`/`on`) and redeploy
# to halt the affected endpoints with 503. See
# docs/runbooks/incident-response.md for the playbook.
# KILL_SWITCH_SCORE=
# KILL_SWITCH_BATTLES=
# KILL_SWITCH_LEADERBOARD=
# KILL_SWITCH_SIGNUPS=


# ---------------------------------------------------------------------
# Deferred to Launch 2: Stripe + holymog+ subscription
# ---------------------------------------------------------------------
# Launch 1 ships with no monetization — these stay unset. The code
# paths exist but isSubscriber() always returns false until Stripe is
# wired and the subscription products are created in the dashboard.
#
# When you do ship paid cosmetics / holymog+:
#   1. Create the products in Stripe Dashboard
#   2. Set STRIPE_SECRET_KEY (server-only) + the publishable key
#   3. Configure the webhook endpoint pointing at /api/webhooks/stripe
#      and put its signing secret in STRIPE_WEBHOOK_SECRET
#   4. Set the recurring-subscription price IDs for monthly + annual
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_PRICE_PLUS_MONTHLY=
# STRIPE_PRICE_PLUS_ANNUAL=
